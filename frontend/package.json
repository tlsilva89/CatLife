{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "unocss \"src/**/*.html\" \"src/**/*.ts\" -o src/uno.css --watch & ng serve",
    "build": "unocss \"src/**/*.html\" \"src/**/*.ts\" -o src/uno.css && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@apollo/client": "^4.1.6",
    "apollo-angular": "^13.0.0",
    "graphql": "^16.13.1",
    "marked": "^17.0.4",
    "ngx-markdown": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@iconify-json/ph": "^1.2.2",
    "@unocss/cli": "^66.6.5",
    "@unocss/preset-icons": "^66.6.5",
    "@unocss/preset-uno": "^66.6.5",
    "@unocss/preset-web-fonts": "^66.6.5",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "unocss": "^66.6.5",
    "vitest": "^4.0.8"
  }
}
